  <main>
    <section class="hero">
      <div class="container">
        <div>
          <p class="kicker">KLV Holzminden</p>
          <h2>Leichtathletik im Landkreis Holzminden</h2>
          <p class="lead">Aktuelles, Termine, Ergebnisse und Informationen zum Kreisleichtathletikverband Holzminden.</p>
          <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap">
