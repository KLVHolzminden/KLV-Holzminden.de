            <a class="btn outline" href="ergebnisse.html">Ergebnisse &amp; Bestenlisten</a>
          </div>
        </div>
        <div class="heroimg">
          <img src="assets/logo01.jpg" alt="Kreisleichtathletikverband Holzminden Logo" style="object-fit:contain; background:white; border-radius:8px; padding:10px; max-height:140px;" />
